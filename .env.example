# Database (PostgreSQL) - Prisma 5 requires standard postgresql:// URL
# Example: postgresql://user:password@localhost:5432/iphone_dropship
# For Docker: postgresql://postgres:postgres@localhost:5432/iphone_dropship
DATABASE_URL="postgresql://user:password@localhost:5432/iphone_dropship"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
ADMIN_PASSWORD="YourStr0ng!Pass123"  # Min 12 chars, for db:seed

# E2E admin tests (optional): account with role ADMIN
# E2E_ADMIN_EMAIL="e2e.mmrjs12f2qyd@example.com"
# E2E_ADMIN_PASSWORD="your-admin-password"

# Email (Resend) — регистрация, сброс пароля, заказы
# RESEND_API_KEY="re_xxx"   # https://resend.com/api-keys
#
# Адрес отправителя: домен должен быть добавлен и Verified в Resend → Domains (DNS TXT от Resend у регистратора).
# После смены сайта на phonefree.uk здесь тоже нужен адрес @phonefree.uk, не старый домен.
# EMAIL_FROM="PhoneFree <noreply@phonefree.uk>"
# или: EMAIL_FROM="noreply@phonefree.uk"
# NEXT_PUBLIC_SITE_NAME="iPhone Store"
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Уведомления администратору (например, когда клиент загрузил скрин оплаты).
# Можно несколько адресов через запятую.
# ADMIN_NOTIFICATION_EMAIL="orders@yourdomain.com"

# Optional: Payments
# STRIPE_SECRET_KEY=
