# Database (PostgreSQL) - Prisma 5 requires standard postgresql:// URL
# Example: postgresql://user:password@localhost:5432/iphone_dropship
# For Docker: postgresql://postgres:postgres@localhost:5432/iphone_dropship
DATABASE_URL="postgresql://user:password@localhost:5432/iphone_dropship"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
ADMIN_PASSWORD="YourStr0ng!Pass123"  # Min 12 chars, for db:seed

# SMS (Twilio) - required in production for phone registration (verification code)
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# Use either a Messaging Service SID (recommended) or a Twilio phone number:
# TWILIO_MESSAGING_SERVICE_SID="MG..."
# TWILIO_PHONE_NUMBER="+1..."

# Email (Resend) - order emails, password reset; not required for phone-only signup
# Get API key at https://resend.com - free tier: 100 emails/day
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="noreply@yourdomain.com"  # Must be verified in Resend
# ADMIN_NOTIFICATION_EMAIL="support@yourdomain.com"  # Comma-separated; payment screenshots + free iPhone / cash payout requests
# NEXT_PUBLIC_SITE_NAME="iPhone Store"
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Optional: Payments
# STRIPE_SECRET_KEY=
